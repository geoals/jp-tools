# yt-mine configuration
# Copy to .env and adjust values as needed.

# JP_TOOLS_DB_PATH=yt-mine.db
# JP_TOOLS_AUDIO_DIR=audio
# JP_TOOLS_MEDIA_DIR=media
# JP_TOOLS_LISTEN_ADDR=0.0.0.0:3000
# JP_TOOLS_TRANSCRIBE_SCRIPT=scripts/transcribe.py
# JP_TOOLS_WHISPER_CPU_THREADS=0
# JP_TOOLS_WHISPER_DEVICE=auto

# Dictionaries (optional — enables VocabDef on exported cards)
# Comma-separated list of Yomitan dictionary zip files.
# JP_TOOLS_DICTIONARY_PATHS=三省堂国語辞典第八版.zip,jitendex-yomitan.zip,NHK2016.zip
# Legacy single-path form also supported:
# JP_TOOLS_DICTIONARY_PATH=jitendex.zip

# Anki export — model/deck/field names to match your existing note type.
# Defaults match the "Japanese sentences" model used by Yomitan.
# Set a field to empty string to skip it (e.g. JP_TOOLS_ANKI_FIELD_IMAGE=).
# JP_TOOLS_ANKI_URL=http://localhost:8765
# JP_TOOLS_ANKI_MODEL=Japanese sentences
# JP_TOOLS_ANKI_DECK=Japanese
# JP_TOOLS_ANKI_FIELD_VOCAB=VocabKanji
# JP_TOOLS_ANKI_FIELD_DEFINITION=VocabDef
# JP_TOOLS_ANKI_FIELD_SENTENCE=SentKanji
# JP_TOOLS_ANKI_FIELD_IMAGE=Image
# JP_TOOLS_ANKI_FIELD_AUDIO=SentAudio
# JP_TOOLS_ANKI_FIELD_SOURCE=Document
